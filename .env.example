# === Application ===
APP_ENV=development
APP_SECRET_KEY=change-me-to-64-plus-chars-random-string-here-please
APP_DEBUG=true
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === Database (Railway provides DATABASE_URL automatically) ===
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/marketplace

# === Redis (Railway provides REDIS_URL automatically) ===
REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_SECRET_KEY=change-me-jwt-secret-64-chars-minimum-for-hs256-security
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# === Bot Token Encryption (Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
BOT_TOKEN_ENCRYPTION_KEY=change-me-fernet-key-here

# === Telegram ===
# Main platform bot (for admin notifications)
PLATFORM_BOT_TOKEN=

# === S3 / Storage ===
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=marketplace-products
S3_PUBLIC_URL=http://localhost:9000/marketplace-products

# === Sentry ===
SENTRY_DSN=

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@marketplace.uz

# === SMS (Eskiz) ===
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=marketplace

# === Payments ===
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# === Mini App ===
MINIAPP_URL=http://localhost:5174
